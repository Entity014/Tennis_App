<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121214"
    tools:context=".MainActivity">

    <!-- Glowing Background Circle Top-Right -->
    <View
        android:id="@+id/bg_glow_top"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_gradient_circle_purple"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        android:alpha="0.25"/>

    <!-- Glowing Background Circle Bottom-Left -->
    <View
        android:id="@+id/bg_glow_bottom"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:background="@drawable/bg_gradient_circle_teal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="-120dp"
        android:layout_marginStart="-120dp"
        android:alpha="0.2"/>

    <!-- ==================== 1. LOCKED VIEW ==================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_locked"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <!-- App Logo & Lock Status -->
        <LinearLayout
            android:id="@+id/lock_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_secure"
                app:tint="#FF3700B3"
                android:contentDescription="Locked Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVICE LOCKED"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tv_lock_status_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter PIN to activate device"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- PIN Display Dots -->
        <LinearLayout
            android:id="@+id/layout_pin_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/lock_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:id="@+id/dot1" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_icon_ring" android:alpha="0.3"/>
            <View android:id="@+id/dot2" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_icon_ring" android:alpha="0.3"/>
            <View android:id="@+id/dot3" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_icon_ring" android:alpha="0.3"/>
            <View android:id="@+id/dot4" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_icon_ring" android:alpha="0.3"/>
            <View android:id="@+id/dot5" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_icon_ring" android:alpha="0.3"/>
            <View android:id="@+id/dot6" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_icon_ring" android:alpha="0.3"/>
        </LinearLayout>

        <!-- Numeric Keypad Grid -->
        <GridLayout
            android:id="@+id/grid_keypad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4"
            android:alignmentMode="alignBounds"
            android:columnOrderPreserved="false"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layout_pin_dots"
            app:layout_constraintBottom_toTopOf="@id/layout_lock_footer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Buttons from 1 to 9 -->
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_1" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="1" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_2" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="2" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_3" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="3" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_4" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="4" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_5" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="5" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_6" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="6" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_7" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="7" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_8" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="8" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_9" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="9" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_clear" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="C" android:textColor="#FF6200EE" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_icon_ring"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_0" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp" android:background="@drawable/bg_icon_ring" app:strokeColor="#3A3A40" app:strokeWidth="1dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_key_enter" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp" android:text="OK" android:textColor="#FF03DAC5" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_icon_ring"/>
        </GridLayout>

        <!-- Lock Footer -->
        <LinearLayout
            android:id="@+id/layout_lock_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="32dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_lock_device_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Device ID: Getting..."
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:gravity="start"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_goto_settings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin"
                android:textColor="#FF03DAC5"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_preferences"
                app:iconTint="#FF03DAC5"
                app:iconSize="14dp"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ==================== 2. ACTIVE VIEW ==================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_active"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Active Header -->
        <LinearLayout
            android:id="@+id/active_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="50dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSION ACTIVE"
                android:textColor="#FF03DAC5"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <!-- Pulsing green status light layout -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_icon_ring"
                    android:backgroundTint="#FF03DAC5"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device unlocked"
                    android:textColor="#B3FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Premium Glassmorphic Circle Timer Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_timer"
            android:layout_width="260dp"
            android:layout_height="260dp"
            app:cardCornerRadius="130dp"
            app:cardBackgroundColor="#1F1F23"
            app:strokeWidth="2dp"
            app:strokeColor="#3A3A40"
            app:layout_constraintTop_toBottomOf="@id/active_header"
            app:layout_constraintBottom_toTopOf="@id/btn_finish_session"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <!-- Circular Progress Indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    app:indicatorSize="210dp"
                    app:trackThickness="10dp"
                    app:indicatorColor="#FF03DAC5"
                    app:trackColor="#2A2A30"
                    android:progress="100"
                    android:max="100"
                    android:indeterminate="false"/>


                <!-- Time text overlay -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_remaining_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="#FFFFFF"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REMAINING"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- battery & session status -->
        <TextView
            android:id="@+id/tv_session_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Battery: 100% | Sync Active"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/card_timer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Finish early / Lock device button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_finish_session"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="48dp"
            android:layout_marginBottom="60dp"
            android:text="Lock Device"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:backgroundTint="#FF6200EE"
            app:elevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ==================== 3. ADMIN SETTINGS VIEW ==================== -->
    <ScrollView
        android:id="@+id/layout_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADMIN DASHBOARD"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.05"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"/>

            <!-- Device Owner Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1F1F23"
                app:strokeWidth="1dp"
                app:strokeColor="#3A3A40"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Device Owner Status:"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_device_owner_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INACTIVE"
                            android:textColor="#FF6200EE"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_adb_instructions_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="To lock down the device properly, make this app the Device Owner by running this ADB command on your computer:"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>

                    <!-- Scrollable ADB Command text box -->
                    <HorizontalScrollView
                        android:id="@+id/layout_adb_box"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="#121214"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tv_adb_command"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="adb shell dpm set-device-owner com.example.tennislockapp/.LockDeviceAdminReceiver"
                            android:textColor="#FF03DAC5"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:textIsSelectable="true"/>
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/tv_adb_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tip: Long-press command to select and copy."
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Accessibility Guard Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1F1F23"
                app:strokeWidth="1dp"
                app:strokeColor="#3A3A40"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Accessibility Guard:"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_accessibility_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INACTIVE"
                            android:textColor="#FFFF6200"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_enable_accessibility"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Activate Accessibility Guard"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="8dp"
                        app:backgroundTint="#FF6200EE"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Configuration Inputs -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Server Base URL (e.g. http://192.168.1.10:3000)"
                android:textColorHint="#80FFFFFF"
                app:hintTextColor="#FF03DAC5"
                app:boxStrokeColor="#FF03DAC5"
                app:boxBackgroundColor="#1F1F23"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_server_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textUri"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Admin PIN (Required for dashboard access)"
                android:textColorHint="#80FFFFFF"
                app:hintTextColor="#FF03DAC5"
                app:boxStrokeColor="#FF03DAC5"
                app:boxBackgroundColor="#1F1F23"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_admin_pin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_exit_kiosk"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Unlock Phone"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#FF6200EE"
                android:layout_marginBottom="12dp"
                android:enabled="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Configuration"
                android:textColor="#121214"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="#FF03DAC5"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back_to_lock"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Cancel"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="32dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
