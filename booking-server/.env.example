# Server configuration
PORT=3001
JWT_SECRET=your_jwt_secret_here
KIOSK_SYNC_SECRET=your_kiosk_sync_secret_here

# PostgreSQL Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tennis_court?schema=public"

# Live Social Login Configuration (Real API credentials)
# Keep empty on localhost to trigger the Simulation Mode automatically.
GOOGLE_CLIENT_ID=your_google_client_id_here

# Thunder Solution API Configuration for Slip Verification
# Leave empty to automatically fallback to Mock Simulation mode for testing.
SLIP_API_KEY=your_slip_api_key_here

# PromptPay Mobile number or Tax ID for generating the QR code
PROMPAY_RECEIVER_ID=0912345678

# SMTP Configuration for Password Reset Emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
